
==================== Final STG: ====================
T15226b.$WStr [InlPrag=INLINE[final] CONLIKE]
  :: forall a. a %1 -> T15226b.Str a
[GblId[DataConWrapper],
 Arity=1,
 Caf=NoCafRefs,
 Str=<SL>,
 Unf=OtherCon []] =
    {} \r [conrep]
        case conrep of $WStr_sat { __DEFAULT -> T15226b.Str [$WStr_sat]; };

T15226b.Str [InlPrag=CONLIKE]
  :: forall {a}. GHC.Internal.Types.Strict a %1 -> T15226b.Str a
[GblId[DataCon],
 Arity=1,
 Caf=NoCafRefs,
 Str=<SL>,
 Unf=OtherCon []] =
    {} \r [eta] T15226b.Str [eta];

T15226b.bar1
  :: forall a.
     GHC.Internal.Maybe.Maybe a
     -> GHC.Internal.Prim.State# GHC.Internal.Prim.RealWorld
     -> (# GHC.Internal.Prim.State# GHC.Internal.Prim.RealWorld,
           T15226b.Str (GHC.Internal.Maybe.Maybe a) #)
[GblId, Arity=2, Str=<L><L>, Cpr=1(, 1), Unf=OtherCon []] =
    {} \r [x void]
        case x of bar1_sat {
        __DEFAULT ->
        let {
          bar1_sat [Occ=Once1] :: T15226b.Str (GHC.Internal.Maybe.Maybe a)
          [LclId, Unf=OtherCon []] =
              T15226b.Str! [bar1_sat];
        } in  GHC.Internal.Types.MkSolo# [bar1_sat];
        };

T15226b.bar
  :: forall a.
     GHC.Internal.Maybe.Maybe a
     -> GHC.Internal.Types.IO (T15226b.Str (GHC.Internal.Maybe.Maybe a))
[GblId, Arity=2, Str=<L><L>, Cpr=1(, 1), Unf=OtherCon []] =
    {} \r [eta void] T15226b.bar1 eta GHC.Internal.Prim.void#;


