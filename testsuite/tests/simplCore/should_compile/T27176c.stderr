$sspec :: Int -> Int -> Int
[LclId,
 Arity=2,
 Str=<S!P(L)><S!P(L)>,
 Cpr=1,
 Unf=Unf{Src=StableSystem, TopLvl=True,
         Value=True, ConLike=True, WorkFree=True, Expandable=True,
         Guidance=ALWAYS_IF(arity=2,unsat_ok=True,boring_ok=False)
         Tmpl= \ (cbA [Occ=Once1!, Dmd=S!P(L)] :: Int)
                 (cbB [Occ=Once1!, Dmd=S!P(L)] :: Int) ->
                 case cbA of { I# cbC ->
                 case cbB of { I# cbD [Occ=Once1] -> I# (+# (*# cbC cbD) cbC) }
                 }}]
$sspec
  = \ (cbA [Dmd=S!P(L)] :: Int) (cbB [Dmd=S!P(L)] :: Int) ->
      case cbA of cwA [Dmd=A] { I# cbC ->
      case cbB of cwB [Dmd=A] { I# cbD -> I# (+# (*# cbC cbD) cbC) }
      }

