
==================== Tidy Rules ====================
"SPEC useAbstractMonad"
    forall (@ s)
           ($dMonadAbstractIOST
              :: Main.MonadAbstractIOST
                   (Main.ReaderT GHC.Types.Int (GHC.ST.ST s))).
      Main.useAbstractMonad @ (Main.ReaderT GHC.Types.Int (GHC.ST.ST s))
                            $dMonadAbstractIOST
      = Main.useAbstractMonad_$suseAbstractMonad @ s


