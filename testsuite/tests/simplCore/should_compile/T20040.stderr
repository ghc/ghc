
==================== Final STG: ====================
$WNil = Nil! [];

$WCons = \r [conrep conrep1] Cons [conrep conrep1];

unSucc1 = \r [ds] ds;

unSucc = \r [eta] unSucc1 eta;

Rec {
ifoldl' =
    \r [f z ds]
        case ds of wild {
          Nil -> z;
          Cons x xs ->
              case z of z1 {
              __DEFAULT -> case f z1 x of sat { __DEFAULT -> ifoldl' f sat xs; };
              };
        };
end Rec }

Nil = \r [void] Nil [];

Cons = \r [void eta eta] Cons [eta eta];

Z = Z! [];

S = \r [eta] S [eta];


