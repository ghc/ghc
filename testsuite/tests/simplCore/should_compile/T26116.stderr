
==================== Tidy Core rules ====================
"USPEC $cop1 @T @_"
    forall (@a) ($dEq [Occ=Dead] :: Eq (T a)) ($dD :: D a).
      $fCTYPEfa_$cop1 @T @a $dEq $dD
      = \ (x [Occ=Dead] :: T a) -> I# 3#
"USPEC $fCTYPEfa @T @_"
    forall (@a) ($dEq [Occ=Dead] :: Eq (T a)) ($dD :: D a).
      $fCTYPEfa @T @a $dEq $dD
      = $fCTYPEfa_$s$fCTYPEfa @a $dD


