      res = a7;
      ccall printf("Before jump 7\n");
      goto END;
    }
    case 8: {
      ccall printf("Inside branch 8\n");
      res = a8;
      ccall printf("Before jump 8\n");
      goto END;
    }
    default: {
      ccall printf("Inside default branch\n");
      res = x * (2 :: I64);
      ccall printf("Before jump default\n");
      goto END;
    }
  }
END:
  ccall printf("Return\n");
  ccall fflush(NULL);
  return (res);
}
