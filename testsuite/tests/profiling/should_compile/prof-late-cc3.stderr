M.doStuff [InlPrag=INLINE (sat-args=1)]
  :: forall {b}.
     GHC.Internal.Show.Show b =>
     b -> GHC.Internal.Types.IO b
[GblId, Arity=2, Unf=OtherCon []]
M.doStuff
  = \ (@b_aIz)
      ($dShow_sMs [Occ=OnceL1] :: GHC.Internal.Show.Show b_aIz)
      (eta_sMt :: b_aIz) ->
      scctick<doStuffCostCentreScope>
      let {
        doStuff_sat_sMv [Occ=Once1] :: GHC.Internal.Types.IO b_aIz
        [LclId]
        doStuff_sat_sMv
          = GHC.Internal.Base.return
              @GHC.Internal.Types.IO
              GHC.Internal.Base.$fMonadIO
              @b_aIz
              eta_sMt } in
      let {
        doStuff_sat_sMu [Occ=Once1] :: GHC.Internal.Types.IO ()
        [LclId]
        doStuff_sat_sMu
          = GHC.Internal.System.IO.print @b_aIz $dShow_sMs eta_sMt } in
      GHC.Internal.Base.>>
        @GHC.Internal.Types.IO
        GHC.Internal.Base.$fMonadIO
        @()
        @b_aIz
        doStuff_sat_sMu
        doStuff_sat_sMv



